{
  "rewrites": [
    { "source": "/landing", "destination": "/ai-growth-team-landing-page.html" },
    { "source": "/ai-growth-team", "destination": "/ai-growth-team-landing-page.html" },
    { "source": "/dashboard", "destination": "/client-dashboard-main.html" },
    { "source": "/roi", "destination": "/roi-calculator.html" },
    { "source": "/checklist", "destination": "/dtc-growth-checklist.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
